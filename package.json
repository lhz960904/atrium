{
  "name": "atrium",
  "version": "0.0.5",
  "private": true,
  "description": "Atrium — personal AI workspace",
  "main": "./out/main/index.js",
  "author": "Haoze",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome check --write .",
    "routes:generate": "tsr generate",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run routes:generate && bun run typecheck:node && bun run typecheck:web",
    "check": "bun run lint && bun run typecheck",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:reset-chat": "bash scripts/reset-chat.sh",
    "sync:models": "bun run scripts/sync-models.ts",
    "build": "bun run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "bun run build && electron-builder --dir",
    "build:mac": "bun run build && electron-builder --mac",
    "build:win": "bun run build && electron-builder --win",
    "build:linux": "bun run build && electron-builder --linux"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.25.0",
    "@ai-sdk/anthropic": "^3",
    "@ai-sdk/google": "^3",
    "@ai-sdk/openai-compatible": "^2",
    "@ai-sdk/react": "^3",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@hono/node-server": "^1",
    "@lobehub/icons-static-svg": "^1.91.0",
    "@mozilla/readability": "^0.6.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.16",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^4",
    "@tanstack/react-router": "^1.170.8",
    "@tiptap/extension-document": "^3.25.0",
    "@tiptap/extension-hard-break": "^3.25.0",
    "@tiptap/extension-mention": "^3.25.0",
    "@tiptap/extension-paragraph": "^3.25.0",
    "@tiptap/extension-text": "^3.25.0",
    "@tiptap/extensions": "^3.25.0",
    "@tiptap/pm": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/suggestion": "^3.25.0",
    "@trpc/client": "10.45.2",
    "@trpc/react-query": "10.45.4",
    "@trpc/server": "10.45.2",
    "ai": "^6",
    "assistant-stream": "^0.3.18",
    "better-sqlite3": "^12.10.0",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "electron-conf": "^1.3.0",
    "electron-log": "^5.4.4",
    "electron-trpc": "^0.7.1",
    "fast-glob": "^3.3.3",
    "hono": "^4",
    "i18next": "^26.3.1",
    "jieba-wasm": "^2.4.0",
    "katex": "^0.17.0",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "prism-react-renderer": "^2.4.1",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "remark-math": "^6.0.0",
    "shell-quote": "^1.8.4",
    "streamdown": "^2.5.0",
    "turndown": "^7.2.4",
    "use-stick-to-bottom": "^1.1.6",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@libsql/client": "^0.17.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-cli": "^1.167",
    "@tanstack/router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/shell-quote": "^1.7.5",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.1.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "trustedDependencies": [
    "electron",
    "esbuild",
    "better-sqlite3"
  ]
}
