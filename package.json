{
  "name": "atrium",
  "version": "0.0.1",
  "private": true,
  "description": "Atrium — personal AI workspace",
  "main": "./out/main/index.js",
  "author": "Haoze",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome check --write .",
    "routes:generate": "bunx @tanstack/router-cli@latest generate",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run routes:generate && bun run typecheck:node && bun run typecheck:web",
    "check": "bun run lint && bun run typecheck",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "build": "bun run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "bun run build && electron-builder --dir",
    "build:mac": "bun run build && electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@lobehub/icons-static-svg": "^1.91.0",
    "@tanstack/react-query": "^4",
    "@tanstack/react-router": "^1.170.8",
    "@trpc/client": "10.45.2",
    "@trpc/react-query": "10.45.4",
    "@trpc/server": "10.45.2",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "electron-conf": "^1.3.0",
    "electron-trpc": "^0.7.1",
    "lucide-react": "^1.16.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@libsql/client": "^0.17.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "trustedDependencies": [
    "electron",
    "esbuild"
  ]
}
